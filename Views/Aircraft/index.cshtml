@using AircraftMRO.Application.DTOs.Aircraft
@using AircraftMRO.Common.Pagination

@model PagedResult<AircraftListDto>

@{
    ViewData["Title"] = "Aircraft Fleet";
}

<div class="container-fluid px-0">

    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4 based-text">

        <div>

            <h3 class="fw-bold mb-1">
                Aircraft Fleet
            </h3>

            <p class="text-muted mb-0">
                Manage and monitor all registered aircraft.
            </p>

        </div>

        <!-- Create Button -->
        <button class="btn btn-based rounded-pill px-4" onclick="openCrudModal('/Aircraft/Create')">

            <i class="bi bi-plus-circle me-2"></i>
            Add Aircraft

        </button>

    </div>
    <!-- Filters -->
    <div class="card border-0 shadow-sm rounded-4 mb-2 based-filter-bg">

        <div class="card-body">

            <form method="get">

                <div class="row g-3 align-items-end">

                    <!-- Search -->
                    <div class="col-md-4">

                        <label class="form-label fw-semibold">
                            Search
                        </label>

                        <input type="text" name="Search" value="@Context.Request.Query["Search"]" class="form-control"
                               placeholder="ID or Tail number or model" />

                    </div>

                    <!-- Page Size -->
                    <div class="col-md-2">

                        <label class="form-label fw-semibold">
                            Page Size
                        </label>

                        <select name="PageSize" class="form-select">

                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>

                        </select>

                    </div>

                    <!-- Actions -->
                    <div class="col-md-3">

                        <button type="submit" class="btn btn-based px-4">

                            <i class="bi bi-search me-2"></i>
                            Filter

                        </button>

                        <a asp-action="Index" class="btn btn-light border ms-2">

                            Reset

                        </a>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-2 p-md-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0 small">

                    <thead class="table-light text-center based-bg-table-header">

                        <tr>

                            <th class="py-2 based-text text-nowrap">ID</th>
                            <th class="py-2 based-text text-nowrap">Aircraft</th>
                            <th class="py-2 based-text text-nowrap">Manufacturer</th>
                            <th class="py-2 based-text text-nowrap">Status</th>
                            <th class="py-2 based-text text-nowrap">Flight Hours</th>
                            <th class="py-2 based-text text-nowrap">Maintenance</th>
                            <th class="py-2 based-text text-nowrap">Work Orders</th>
                            <th class="py-2 based-text text-nowrap">Alerts</th>
                            <th class="py-2 based-text text-nowrap">Deleted</th>
                            <th class="py-2 based-text text-nowrap">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Items != null && Model.Items.Any())
                        {
                            @foreach (AircraftListDto item in Model.Items)
                            {
                                <tr class="text-center align-middle">
                                    <td class="py-2 based-text text-nowrap">
                                        @item.Id
                                    </td>

                                    <!-- Aircraft -->
                                    <td class="py-2 based-text text-nowrap">

                                        <div class="d-flex flex-column align-items-center">

                                            <div class="fw-semibold">
                                                @item.TailNumber
                                            </div>

                                            <small class="text-muted">
                                                @item.Model
                                            </small>

                                        </div>

                                    </td>

                                    <!-- Manufacturer -->
                                    <td class="py-2 based-text text-nowrap">
                                        @item.Manufacturer
                                    </td>

                                    <!-- Status -->
                                    <td class="py-2 based-text text-nowrap">

                                        @if (item.Status.ToString() == "Active")
                                        {
                                            <span class="badge text-bg-success fw-normal">
                                                @item.Status
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill text-bg-secondary px-3 py-2">
                                                @item.Status
                                            </span>
                                        }

                                    </td>

                                    <!-- Flight Hours -->
                                    <td class="py-2 based-text text-nowrap">

                                        <span class="fw-semibold">
                                            @item.TotalFlightHours hrs
                                        </span>

                                    </td>

                                    <!-- Maintenance -->
                                    <td class="py-2 based-text text-nowrap">

                                        <span class="badge text-bg-light border px-3 py-2">
                                            @item.MaintenanceCount
                                        </span>

                                    </td>

                                    <!-- Work Orders -->
                                    <td class="py-2 based-text text-nowrap">

                                        <span class="badge text-bg-light border px-3 py-2">
                                            @item.WorkOrderCount
                                        </span>

                                    </td>

                                    <!-- Alerts -->
                                    <td class="py-2 based-text text-nowrap">

                                        <span class="badge text-bg-light border px-3 py-2">
                                            @item.AlertCount
                                        </span>

                                    </td>

                                    <!-- IsDeleted -->
                                    <td>
                                        @if (item.IsDeleted)
                                        {
                                            <span class="badge bg-danger">
                                                YES
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge  bg-success">
                                                NO
                                            </span>
                                        }
                                    </td>

                                    <!-- Actions -->
                                    <td class="py-2 based-text text-nowrap">

                                        <div class="d-flex flex-wrap justify-content-center gap-2">

                                            <!-- Details -->
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border">

                                                <i class="bi bi-eye"></i>

                                            </a>

                                            <!-- Edit -->
                                            <button class="btn btn-sm btn-outline-primary"
                                                    onclick="openCrudModal('/Aircraft/Edit/@item.Id')">

                                                <i class="bi bi-pencil"></i>

                                            </button>

                                            <!-- Delete -->
                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="openCrudModal('/Aircraft/Delete/@item.Id')">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="9" class="text-center py-5">

                                    <div class="py-4">

                                        <div class="mb-3">
                                            <i class="bi bi-airplane-engines fs-1 text-muted"></i>
                                        </div>

                                        <h5 class="fw-semibold mb-2">
                                            No Aircraft Available
                                        </h5>

                                        <p class="text-muted mb-4">
                                            Start by adding your first aircraft to the fleet.
                                        </p>

                                        <button class="btn btn-based rounded-pill px-4"
                                                onclick="openCrudModal('/Aircraft/Create')">

                                            <i class="bi bi-plus-circle me-2"></i>
                                            Add Aircraft

                                        </button>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>
                </table>

            </div>

        </div>

    </div>

    <!-- Pagination -->
    @{
        int startPage = Math.Max(1, Model.PageNumber - 2);
        int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
    }

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3 mb-5">
            <ul class="pagination justify-content-center custom-pagination">

                <!-- Previous -->
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-PageNumber="@(Model.PageNumber - 1)"
                       asp-route-Search="@Context.Request.Query["Search"]" asp-route-PageSize="@Model.PageSize">
                        Previous
                    </a>
                </li>

                <!-- First page -->
                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-PageNumber="1"
                           asp-route-Search="@Context.Request.Query["Search"]" asp-route-PageSize="@Model.PageSize">
                            1
                        </a>
                    </li>

                    @if (startPage > 2)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                }

                <!-- Current window -->
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-PageNumber="@i"
                           asp-route-Search="@Context.Request.Query["Search"]" asp-route-PageSize="@Model.PageSize">
                            @i
                        </a>
                    </li>
                }

                <!-- Last page -->
                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }

                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-PageNumber="@Model.TotalPages"
                           asp-route-Search="@Context.Request.Query["Search"]" asp-route-PageSize="@Model.PageSize">
                            @Model.TotalPages
                        </a>
                    </li>
                }

                <!-- Next -->
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-PageNumber="@(Model.PageNumber + 1)"
                       asp-route-Search="@Context.Request.Query["Search"]" asp-route-PageSize="@Model.PageSize">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>
