@using AircraftMRO.Domain.Enums
@using AircraftMRO.Models.ViewModels.WorkOrder

@model WorkOrderEditViewModel

<form asp-action="Edit" method="post">

    @Html.AntiForgeryToken()

    <input asp-for="Id" type="hidden" />

    <div class="modal-header">

        <h5 class="modal-title fw-bold">
            Edit Work Order
        </h5>

        <button type="button" class="btn-close" data-bs-dismiss="modal">
        </button>

    </div>

    <div class="modal-body">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <!-- Aircraft (Read Only) -->
        <div class="mb-3">

            <label class="form-label fw-semibold">
                Aircraft
            </label>

            <input type="hidden" asp-for="AircraftId" />

            <input type="text"
                class="form-control"
                value="@Model.AircraftTailNumber (ID: @Model.AircraftId)"
                readonly />

        </div>
            <!-- Description -->
            <div class="mb-3">

                <label asp-for="Description" class="form-label fw-semibold">
                </label>

                <textarea asp-for="Description"
                        class="form-control"
                        rows="4">
                </textarea>

                <span asp-validation-for="Description"
                    class="text-danger small">
                </span>

            </div>

            <!-- Priority -->
            <div class="mb-3">

                <label asp-for="Priority"
                    class="form-label fw-semibold">
                </label>

                <select asp-for="Priority"
                        class="form-select">

                    @foreach (WorkOrderPriority priority in Enum.GetValues<WorkOrderPriority>())
                    {
                        <option value="@priority">
                            @priority
                        </option>
                    }

                </select>

            </div>

    </div>

    <div class="modal-footer">

        <button type="button"
                class="btn btn-light border"
                data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit"
                class="btn btn-based">

            Update Work Order

        </button>

    </div>

</form>

<partial name="_ValidationScriptsPartial" />