@using AircraftMRO.Application.DTOs.MaintenanceRecord
@using AircraftMRO.Domain.Enums

@model MaintenanceCreateDto

<form asp-action="Create" method="post">

    @Html.AntiForgeryToken()

    <div class="modal-header">

        <h5 class="modal-title fw-bold">
            Add Maintenance Record
        </h5>

        <button type="button" class="btn-close" data-bs-dismiss="modal">
        </button>

    </div>

    <div class="modal-body">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3">
        </div>

        <!-- Work Order -->

        <div class="mb-3">

            <label asp-for="WorkOrderId" class="form-label fw-semibold">

                Work Order

            </label>

            <select asp-for="WorkOrderId" asp-items="@(new SelectList(Model.WorkOrders, "Id", "DisplayText"))"
                    class="form-select" data-tom-select data-placeholder="Search work order...">
                <option value="">
                    Select Work Order
                </option>
            </select>

            <span asp-validation-for="WorkOrderId" class="text-danger small">
            </span>

        </div>

        <!-- Type -->

        <div class="mb-3">

            <label asp-for="Type" class="form-label fw-semibold">
            </label>

            <select asp-for="Type" asp-items="Html.GetEnumSelectList<MaintenanceType>()" class="form-select">
            </select>

            <span asp-validation-for="Type" class="text-danger small">
            </span>

        </div>

        <!-- Scheduled Date -->

        <div class="mb-3">

            <label asp-for="ScheduledDate" class="form-label fw-semibold">
            </label>

            <input asp-for="ScheduledDate" type="datetime-local" class="form-control" />

            <span asp-validation-for="ScheduledDate" class="text-danger small">
            </span>

        </div>

        <!-- Notes -->

        <div class="mb-3">

            <label asp-for="Notes" class="form-label fw-semibold">
            </label>

            <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Enter maintenance notes">
            </textarea>

            <span asp-validation-for="Notes" class="text-danger small">
            </span>

        </div>

    </div>

    <div class="modal-footer">

        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit" class="btn btn-based">

            Save Maintenance Record

        </button>

    </div>

</form>

<partial name="_ValidationScriptsPartial" />