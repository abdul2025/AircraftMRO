<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AircraftMRO</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AircraftMRO.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- Top Navbar -->
    <header>
        <nav class="navbar navbar bg border-bottom navbar-expand-lg">
            <div class="container-fluid">

                <!-- Sidebar Toggle -->
                <button class="btn btn-outline-dark me-3"  type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#sidebar" aria-controls="sidebar">
                    <i class="bi bi-list"></i>
                </button>

                <!-- Brand -->
                <a class="navbar-brand based-text fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    AircraftMRO
                </a>


                <!-- Navbar Items -->
                <div class="collapse navbar-collapse" id="topNavbar">

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Profile">
                                <i class="bi bi-person-circle fs-5"></i>
                            </a>
                        </li>

                    </ul>

                </div>

            </div>
        </nav>
    </header>

    <!-- Sidebar -->
    <div class="offcanvas offcanvas-start text-bg" tabindex="-1" id="sidebar" aria-labelledby="sidebarLabel" style="background-color: #000107;">

        <!-- Sidebar Header -->
        <div class="offcanvas-header border-bottom">

            <h5 class="offcanvas-title based-text fw-bold" id="sidebarLabel">
                AircraftMRO
            </h5>

            <button type="button" class="btn-close btn-close-dark" data-bs-dismiss="offcanvas" aria-label="Close">
            </button>

        </div>

        <!-- Sidebar Body -->
        <div class="offcanvas-body d-flex flex-column p-0">

            <ul class="nav nav-pills flex-column p-3">

                <li class="nav-item mb-2 fw-bold">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-house-door me-2"></i>
                        Home
                    </a>
                </li>

                <li class="nav-item mb-2 fw-bold">
                    <a asp-controller="Aircraft" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-airplane me-2"></i>
                        Aircraft
                    </a>
                </li>

                <li class="nav-item mb-2 fw-bold">
                    <a asp-controller="Maintenance" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-tools me-2"></i>
                        Maintenance
                    </a>
                </li>

                <li class="nav-item mb-2 fw-bold">
                    <a asp-controller="WorkOrders" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-clipboard-check me-2 "></i>
                        Work Orders
                    </a>
                </li>

                <li class="nav-item mb-2 fw-bold">
                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-speedometer2 me-2"></i>
                        Dashboard
                    </a>
                </li>

            </ul>

            <!-- Bottom Section -->
            <div class="mt-auto p-3 border-top">
                <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-dark w-100">
                    <i class="bi bi-person-circle me-2"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container-fluid mt-4">

        <main role="main" class="pb-3">
            @RenderBody()
        </main>

    </div>

    <!-- Footer -->
    <footer class="border-top footer text-muted mt-4 fw-bold">
        <div class="container py-3">
            &copy; 2026 - AircraftMRO
        </div>
    </footer>

    @await Html.PartialAsync("_CrudModal")


    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    // Custom JS
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/error.js"></script>
    <script src="~/js/crud-modal.js"></script>

    // Allow using JS and CSS globally over the prject
    @await RenderSectionAsync("Scripts", required: false)
    @await RenderSectionAsync("Styles", required: false)
</body>

</html>