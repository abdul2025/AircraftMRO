@using AircraftMRO.Application.DTOs.Alert
@using AircraftMRO.Common.Pagination
@using AircraftMRO.Domain.Enums


@model PagedResult<AlertListDto>

@{
    ViewData["Title"] = "Alerts";
}

<div class="container-fluid px-0">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-1">Alerts</h3>
            <p class="text-muted mb-0">
                Monitor system generated alerts and notifications.
            </p>
        </div>

    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm rounded-4 mb-3 based-filter-bg">

        <div class="card-body">

            <form method="get">

                <div class="row g-3 align-items-end">

                    <div class="col-md-4">

                        <label class="form-label fw-semibold">
                            Search
                        </label>

                        <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control"
                               placeholder="Title, message or aircraft" />

                    </div>

                    <div class="col-md-3">

                        <label class="form-label fw-semibold">
                            Status
                        </label>

                        <select name="resolved" class="form-select">

                            <option value="">All</option>
                            <option value="false">Open</option>
                            <option value="true">Resolved</option>

                        </select>

                    </div>

                    <div class="col-md-2">

                        <label class="form-label fw-semibold">
                            Page Size
                        </label>

                        <select name="pageSize" class="form-select">

                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>

                        </select>

                    </div>

                    <div class="col-md-3">

                        <button type="submit" class="btn btn-based">

                            <i class="bi bi-search me-2"></i>
                            Filter

                        </button>

                        <a asp-action="Index" class="btn btn-light border ms-2">

                            Reset

                        </a>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-2 p-md-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light based-bg-table-header text-center">

                        <tr>

                            <th>Alert</th>
                            <th>Aircraft</th>
                            <th>Severity</th>
                            <th>Notification</th>
                            <th>Work Order IDs</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th>Resolved At</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                <tr class="text-center">

                                    <td>
                                        <div class="fw-semibold">
                                            @item.Title
                                        </div>
                                    </td>

                                    <td>
                                        @item.AircraftTailNumber
                                    </td>

                                    <td>

                                        @switch (item.Severity)
                                        {
                                            case AlertSeverity.Critical:
                                                <span class="badge bg-danger">
                                                    Critical
                                                </span>
                                                break;

                                            case AlertSeverity.Warning:
                                                <span class="badge bg-warning text-dark">
                                                    Warning
                                                </span>
                                                break;

                                            default:
                                                <span class="badge bg-info">
                                                    Info
                                                </span>
                                                break;
                                        }

                                    </td>

                                    

                                    <td>

                                        @if (item.NotificationSent)
                                        {
                                            <span class="badge bg-success">
                                                Sent
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                Pending
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (item.WorkOrderIds != null)
                                        {
                                            <span class="badge text-bg-light border">
                                                @string.Join(separator: "-", item.WorkOrderIds)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                -
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (item.IsResolved)
                                        {
                                            <span class="badge bg-success">
                                                Resolved
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Open
                                            </span>
                                        }

                                    </td>
                                    <td>
                                        @item.CreatedAt.ToString("dd MMM yyyy HH:mm")
                                    </td>
                                    <td>
                                        @(item.ResolvedAt?.ToString("dd MMM yyyy HH:mm") ?? "-")
                                    </tr>
                                }
                            }
                        else
                            {
                                <tr>

                                    <td colspan="7" class="text-center py-5">

                                        <i class="bi bi-bell fs-1 text-muted"></i>

                                        <h5 class="mt-3">
                                            No Alerts Found
                                        </h5>

                                        <p class="text-muted">
                                            There are currently no active alerts.
                                        </p>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>