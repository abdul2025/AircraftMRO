@using AircraftMRO.Application.DTOs.Aircraft
@model AircraftEditDto

<form asp-action="Edit" method="post">

    @Html.AntiForgeryToken()

    <input asp-for="Id" type="hidden" />

    <div class="modal-header">

        <h5 class="modal-title fw-bold">
            Edit Aircraft
        </h5>

        <button type="button"
                class="btn-close"
                data-bs-dismiss="modal">
        </button>

    </div>

    <div class="modal-body">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <!-- Tail Number -->
        <div class="mb-3">

            <label asp-for="TailNumber"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="TailNumber"
                   class="form-control bg-light"
                   readonly />

            <small class="text-muted">
                Tail number cannot be changed.
            </small>

            <span asp-validation-for="TailNumber"
                  class="text-danger small">
            </span>

        </div>

        <!-- Model -->
        <div class="mb-3">

            <label asp-for="Model"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="Model"
                   class="form-control" />

            <span asp-validation-for="Model"
                  class="text-danger small">
            </span>

        </div>

        <!-- Manufacturer -->
        <div class="mb-3">

            <label asp-for="Manufacturer"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="Manufacturer"
                   class="form-control" />

            <span asp-validation-for="Manufacturer"
                  class="text-danger small">
            </span>

        </div>

    </div>

    <div class="modal-footer">

        <button type="button"
                class="btn btn-light border"
                data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit"
                class="btn btn-primary">

            Update Aircraft

        </button>

    </div>

</form>

<partial name="_ValidationScriptsPartial" />