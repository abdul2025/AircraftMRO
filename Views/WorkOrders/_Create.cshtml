@using AircraftMRO.Models.Enums
@using AircraftMRO.Models.ViewModels.WorkOrder

@model WorkOrderCreateViewModel

<form asp-action="Create" method="post">

    @Html.AntiForgeryToken()

    <div class="modal-header">

        <h5 class="modal-title fw-bold">
            Add Work Order
        </h5>

        <button type="button" class="btn-close" data-bs-dismiss="modal">
        </button>

    </div>

    <div class="modal-body">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3">
        </div>

        <!-- Aircraft -->
        <div class="mb-3">

            <label asp-for="AircraftId" class="form-label fw-semibold">
                Aircraft
            </label>

            <select asp-for="AircraftId"
                    asp-items="Model.Aircrafts"
                    class="form-select"
                    data-tom-select
                    data-placeholder="Search aircraft...">

                <option value="">
                    Select Aircraft
                </option>

            </select>

            <span asp-validation-for="AircraftId" class="text-danger small">
            </span>

        </div>

        <!-- Description -->
        <div class="mb-3">

            <label asp-for="Description" class="form-label fw-semibold">
            </label>

            <textarea asp-for="Description" class="form-control" rows="4"
                      placeholder="Describe the maintenance work required">
            </textarea>

            <span asp-validation-for="Description" class="text-danger small">
            </span>

        </div>

        <!-- Priority -->
        <div class="mb-3">

            <label asp-for="Priority" class="form-label fw-semibold">
            </label>

            <select asp-for="Priority" class="form-select">

                @foreach (WorkOrderPriority priority in Enum.GetValues<WorkOrderPriority>())
                {
                    <option value="@priority">
                        @priority
                    </option>
                }

            </select>

            <span asp-validation-for="Priority" class="text-danger small">
            </span>

        </div>

        

    </div>

    <div class="modal-footer">

        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit" class="btn btn-based">

            Save Work Order

        </button>

    </div>

</form>

<partial name="_ValidationScriptsPartial" />